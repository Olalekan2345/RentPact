# ── Arc Testnet (public network config — safe to commit real values) ──
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# Native USDC on Arc testnet (source: docs.arc.io/arc/references/contract-addresses)
NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=0x3600000000000000000000000000000000000000

# Filled in after Phase 2 deployment (see SETUP.md) — leave blank until you have it.
# The deploy script prints both of these — copy them in together.
NEXT_PUBLIC_RENTPACT_ESCROW_ADDRESS=
NEXT_PUBLIC_RENTPACT_DEPLOY_BLOCK=

# Public copy of the arbiter address (same value as ARC_ARBITER_ADDRESS below) so the
# dispute page can show the Tier-2 resolution controls only to the arbiter account.
NEXT_PUBLIC_ARC_ARBITER_ADDRESS=

# ── CCTP V2 (Arc testnet) ──
NEXT_PUBLIC_CCTP_TOKEN_MESSENGER_ADDRESS=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
NEXT_PUBLIC_CCTP_MESSAGE_TRANSMITTER_ADDRESS=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275

# ── Gateway (Arc testnet) ──
NEXT_PUBLIC_GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
NEXT_PUBLIC_GATEWAY_MINTER_ADDRESS=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B

# ── Unsplash (optional — get a free Access Key at unsplash.com/developers) ──
# Without this, property cards fall back to a designed SVG illustration instead
# of a photo. NOTE: the legacy source.unsplash.com keyword-redirect service is
# permanently shut down — this app uses the real api.unsplash.com instead.
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=

# ── Supabase (database + auth — create a free project at supabase.com, see SETUP.md) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses Row Level Security. NEVER expose to the client or commit the real value.
SUPABASE_SERVICE_ROLE_KEY=

# ── Circle Web3 Services (get these from console.circle.com — see SETUP.md) ──
NEXT_PUBLIC_CIRCLE_APP_ID=
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# ── Deployer key, used only by Hardhat for contract deployment. NEVER commit the real value. ──
ARC_DEPLOYER_PRIVATE_KEY=

# Address authorized to call resolveDispute() on RentPactEscrow. For this version it's a
# single trusted address; production should replace it with a multisig/panel (see contract NatSpec).
ARC_ARBITER_ADDRESS=

# ── Mock layer toggle ──
# true  = lib/circle.ts serves dynamically generated mock responses (no Circle credentials needed)
# false = lib/circle.ts calls real Circle Web3 Services APIs (requires the CIRCLE_* keys above)
NEXT_PUBLIC_MOCK_MODE=true
